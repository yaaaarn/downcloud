{
  "name": "downcloud",
  "description": "a simple (and fast) soundcloud downloader",
  "module": "index.ts",
  "type": "module",
  "version": "1.0.0",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/commander": "^2.12.5",
    "bun2nix": "^2.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "start": "bun run index.ts",
    "build": "bun build --compile --minify index.ts --outfile downcloud",
    "postinstall": "bunx bun2nix -o bun.nix"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0"
  }
}
